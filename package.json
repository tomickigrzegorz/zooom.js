{
  "name": "zooom",
  "version": "1.3.0",
  "description": "The easiest way to zooming a photo",
  "main": "dist/zooom.umd.min.js",
  "browser": "dist/zooom.umd.min.js",
  "module": "dist/zooom.es.min.js",
  "types": "dist/types/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/zooom.es.min.js",
      "require": "./dist/zooom.umd.min.js",
      "default": "./dist/zooom.umd.min.js"
    },
    "./slider": {
      "types": "./dist/types/plugins/slider.d.ts",
      "import": "./dist/zooom-slider.es.min.js",
      "require": "./dist/zooom-slider.umd.min.js",
      "default": "./dist/zooom-slider.umd.min.js"
    },
    "./panzoom": {
      "types": "./dist/types/plugins/panzoom.d.ts",
      "import": "./dist/zooom-panzoom.es.min.js",
      "require": "./dist/zooom-panzoom.umd.min.js",
      "default": "./dist/zooom-panzoom.umd.min.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "author": "Grzegorz Tomicki",
  "license": "MIT",
  "homepage": "https://github.com/tomickigrzegorz/zooom.js",
  "scripts": {
    "dev": "concurrently \"yarn style:watch\" \"yarn watch\"",
    "prod": "yarn style:prod && yarn build && yarn build:types",
    "build": "rollup -c --environment PRODUCTION",
    "build:types": "tsc -p tsconfig.types.json",
    "watch": "rollup -c -w",
    "style:watch": "sass --watch sources/scss:docs",
    "style:prod": "sass sources/scss:docs"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/tomickigrzegorz/zooom.js.git"
  },
  "keywords": [
    "zoom",
    "zooom",
    "image",
    "animation"
  ],
  "devDependencies": {
    "@babel/core": "^7.16.12",
    "@babel/eslint-parser": "^7.16.5",
    "@babel/plugin-proposal-class-properties": "^7.16.7",
    "@babel/preset-env": "^7.16.11",
    "@rollup/plugin-babel": "^5.3.0",
    "@rollup/plugin-typescript": "^8.3.0",
    "concurrently": "^7.0.0",
    "eslint": "^8.8.0",
    "eslint-config-prettier": "^8.3.0",
    "eslint-plugin-prettier": "^4.0.0",
    "prettier": "^2.5.1",
    "rollup": "^2.80.0",
    "rollup-plugin-cleanup": "^3.2.1",
    "rollup-plugin-copy": "^3.4.0",
    "rollup-plugin-livereload": "^2.0.5",
    "rollup-plugin-serve": "^1.1.0",
    "rollup-plugin-terser": "^7.0.2",
    "sass": "^1.49.7",
    "tslib": "^2.3.1",
    "typescript": "^4.5.5"
  }
}
